# Puerto donde correra el servidor (Hostinger lo suele asignar el solo, pero lo dejamos configurable)
PORT=4000

# Cambia esto por una cadena larga y aleatoria antes de publicar la app
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Perfiles de la pareja (se crean automaticamente la primera vez que arranca el servidor)
USER1_NAME=Persona 1
USER1_PIN=1234
USER2_NAME=Persona 2
USER2_PIN=5678

NODE_ENV=development
